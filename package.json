{
  "name": "mersey",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx --test harness/src/*.test.ts harness/src/*/*.test.ts harness/src/*/*/*.test.ts",
    "test:coverage": "tsx --test --experimental-test-coverage harness/src/*.test.ts harness/src/*/*.test.ts harness/src/*/*/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint harness apps",
    "lint:fix": "oxlint --fix harness apps",
    "cli": "node --env-file=.env dist/apps/cli/src/index.js",
    "ftv": "node --env-file=.env dist/apps/ftv/src/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.82.0",
    "@inkjs/ui": "2.0.0",
    "ink": "6.8.0",
    "openai": "6.33.0",
    "react": "19.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  },
  "packageManager": "pnpm@10.33.0"
}
